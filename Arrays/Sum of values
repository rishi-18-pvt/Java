adding the values in the array

public class excersice {
    public static void main(String[] args) {
        int [] arr = {12,34,15,6,7,8};
        int sum = 0;
        for(int i = 1; i < arr.length; i ++){
            sum += arr[i];
            
        }
        System.out.println(sum);

    }
}

output: 70
